{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "capscr",
  "version": "0.5.35",
  "identifier": "io.rot.capscr",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node ../scripts/build-hook.mjs --dev",
    "beforeBuildCommand": "node ../scripts/build-hook.mjs --build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$PICTURE/capscr/**",
          "$HOME/Pictures/capscr/**",
          "$APPDATA/io.rot.capscr/**",
          "$APPDATA/capscr/**",
          "$APPDATA/**"
        ]
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "category": "Utility",
    "copyright": "© rot — capscr",
    "shortDescription": "Modern HDR-aware screen capture",
    "longDescription": "capscr is a screen capture tool with HDR support, plugin marketplace, and per-hotkey task chains.",
    "windows": {
      "certificateThumbprint": "6EC3EDE3956F6F4B7423C723397AF66BC9D596BA",
      "digestAlgorithm": "sha256"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/lintowe/capscr/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDOEU2MDgzRDNFMjFDRUIKUldUckhPTFRnMkNPN0ZhTGNZUEx2TFRuS3Nva0EyU0dFWE41bWtzbFAvZmd6c3oweUgyKzJiN2gK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}